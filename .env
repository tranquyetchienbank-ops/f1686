# Cloud Web Server Configuration
# Thêm các biến môi trường ở đây

# Link trang web chính (bắt buộc)
WEB_LINK=https://f1686s.com/home/mine

# Đường dẫn file TapMonkey (bắt buộc)
TAPMONKEY_FILE=tapmonkey/f1686s_naptien.js

# Port server (tùy chọn - Render sẽ tự động set)
PORT=3000

# Node environment (tự động set trên Render)
NODE_ENV=production
